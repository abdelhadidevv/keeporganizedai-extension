{
  "manifest_version": 3,
  "name": "KeepOrganizedAI",
  "version": "1.1.0",
  "description": "AI-powered bookmark organizer. Categorize bookmarks in minutes with fast search and smart folders.",
  "permissions": ["bookmarks", "storage", "sidePanel", "commands"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open side panel"
    }
  }
}
